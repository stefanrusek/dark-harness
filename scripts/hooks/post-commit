#!/bin/sh
# Post-commit hook: warns when N commits have passed since the last
# Refactoring-Round trailer commit. Advisory only -- cannot block a commit.
# Installed via scripts/install-git-hooks.sh (main checkout only). See
# tracking/DH-0141-formalize-a-periodic-refactoring-round-mechanism.md.
set -eu

THRESHOLD="${DH_REFACTOR_THRESHOLD:-15}"

SENTINEL_SHA=$(git log --grep='^Refactoring-Round: DH-[0-9]\+' -1 --format=%H 2>/dev/null || true)

if [ -n "$SENTINEL_SHA" ]; then
	COUNT=$(git rev-list --count "${SENTINEL_SHA}..HEAD")
else
	COUNT=$(git rev-list --count HEAD)
fi

if [ "$COUNT" -ge "$THRESHOLD" ]; then
	cat >&2 <<EOF
================================================================
REFACTORING ROUND DUE: ${COUNT} commits since the last Refactoring-Round trailer (threshold: ${THRESHOLD})
Dispatch Fable using docs/design/refactoring-round-prompt.md to review recent history and file cleanup tickets.
Close the round with a commit carrying: Refactoring-Round: DH-XXXX
================================================================
EOF
fi
